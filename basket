		}
	
		local basketballsFolder = Workspace:FindFirstChild("Basketballs") or Workspace:FindFirstChild("Balls")
		if basketballsFolder then
			debugPrint("Found basketball folder")
			for _, item in pairs(basketballsFolder:GetChildren()) do
				if item:IsA("BasePart") then
					table.insert(balls, item)
				end
			end
		end
	
		local courts = Workspace:FindFirstChild("Courts") or Workspace:FindFirstChild("Court")
		if courts then
			debugPrint("Found courts folder")
			for _, court in pairs(courts:GetChildren()) do
				for _, item in pairs(court:GetDescendants()) do
					if item:IsA("BasePart") then
