								table.insert(balls, item)
								break
							end
						end
					end
				end
			end
		end
	
		if #balls == 0 then
			for _, item in ipairs(Workspace:GetDescendants()) do
				if item:IsA("BasePart") then
					local lowerName = item.Name:lower()
					for _, name in ipairs(potentialNames) do
						if lowerName:find(name) then
							table.insert(balls, item)
							break
						end
					end
				end
			end
		end
		return balls
	end
	
	local PickupCooldowns = {}
	local COOLDOWN_DURATION = 0.5
	
	local function PickupBall()
		if not PickupActive then 
			debugPrint("Pickup not active")
			return 
		end
	
		local Character = LocalPlayer.Character
		if not Character then
			debugPrint("No character")
			return
		end
	
		local HumanoidRootPart = Character:FindFirstChild("HumanoidRootPart")
		if not HumanoidRootPart then
			debugPrint("No HRP")
			return
		end
	
		local closestDistance = 20  
		local targetBall = nil
		local currentTime = os.clock()
	
		for _, basketball in ipairs(findBasketballs()) do
			if PickupCooldowns[basketball] and currentTime < PickupCooldowns[basketball] then
				continue
			end
	
			local distance = (HumanoidRootPart.Position - basketball.Position).Magnitude
			if distance < closestDistance then
				closestDistance = distance
				targetBall = basketball
			end
		end
	
		for ball, cooldownEnd in pairs(PickupCooldowns) do
			if currentTime >= cooldownEnd then
				PickupCooldowns[ball] = nil
			end
		end
	
		if targetBall then
			debugPrint("Attempting pickup of", targetBall:GetFullName(), "at distance", closestDistance)
	
			local success, err = pcall(function()
				firetouchinterest(HumanoidRootPart, targetBall, 0)
				task.wait(0.01)
				firetouchinterest(HumanoidRootPart, targetBall, 1)
			end)
			debugPrint("Touch interest result:", success, err or "success")
	
			local remote = game:GetService("ReplicatedStorage"):FindFirstChild("PickupBall") or 
				game:GetService("ReplicatedStorage"):FindFirstChild("BallPickup")
			if remote then
				pcall(function()
					remote:FireServer(targetBall)
					debugPrint("Remote event fired")
				end)
			end
	
			PickupCooldowns[targetBall] = currentTime + COOLDOWN_DURATION
		else
			debugPrint("No valid basketball found within range")
		end
	end
	
	local function UpdatePickupState()
		if ShootingValue and ShootingValue.Value then
			WasToggledBeforeShooting = Toggle
			PickupActive = false
			SetCollisions(true)
			debugPrint("Shooting - disabling pickup")
		else
			PickupActive = Toggle and (WasToggledBeforeShooting or true) 
			SetCollisions(not Toggle)
			debugPrint("Normal state - PickupActive:", PickupActive)
		end
	end
	
	RunService.Heartbeat:Connect(function()
		if PickupActive then
			PickupBall()
		end
	end)
	
	textButton.MouseButton1Click:Connect(function()
		if ShootingValue and ShootingValue.Value then 
			debugPrint("Clicked while shooting - ignoring")
			return 
		end
	
		Toggle = not Toggle
		debugPrint("Toggle set to:", Toggle)
		textButton.BackgroundColor3 = Toggle and Color3.fromRGB(74, 74, 74) or Color3.fromRGB(15, 15, 15)
		UpdatePickupState()
	end)
	
	LocalPlayer.CharacterAdded:Connect(function(character)
		debugPrint("Character added")
		task.wait(1) 
		if Toggle then
			SetCollisions(false)
		end
		UpdatePickupState()
	end)
	
	LocalPlayer.CharacterRemoving:Connect(function()
		debugPrint("Character removing")
		SetCollisions(true)
	end)
	
	
	if Values and ShootingValue then
		ShootingValue:GetPropertyChangedSignal("Value"):Connect(UpdatePickupState)
	end
	UpdatePickupState()
	debugPrint("Script initialized")
end
