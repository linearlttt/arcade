	local RunService = game:GetService("RunService")
	local ReplicatedStorage = game:GetService("ReplicatedStorage")
	
	-- Player
	local LocalPlayer = Players.LocalPlayer
	
	-- UI
	local Button = script.Parent
	
	-- Config
	local MAX_DISTANCE = 45
	
	-- State
	local enabled = false
	local heartbeatConn
	
	-- Remote
	local GuardEvent = ReplicatedStorage:WaitForChild("Events"):WaitForChild("Guard")
	
	-- Get closest valid target
	local function getClosestTarget()
		local char = LocalPlayer.Character
		if not char then return nil end
	
		local hrp = char:FindFirstChild("HumanoidRootPart")
		if not hrp then return nil end
	
		local closestPlayer
		local closestDist = math.huge
	
		for _, plr in Players:GetPlayers() do
			if plr ~= LocalPlayer and plr.Character then
				local otherHRP = plr.Character:FindFirstChild("HumanoidRootPart")
				local hum = plr.Character:FindFirstChildOfClass("Humanoid")
	
				if otherHRP and hum and hum.Health > 0 then
					local dist = (otherHRP.Position - hrp.Position).Magnitude
					if dist < closestDist and dist <= MAX_DISTANCE then
						closestDist = dist
						closestPlayer = plr
					end
				end
			end
		end
	
		return closestPlayer
	end
	
	-- Heartbeat loop
	local function onHeartbeat()
		if not enabled then
			GuardEvent:FireServer(false)
			return
		end
	
		local target = getClosestTarget()
	
